# Created by https://www.toptal.com/developers/gitignore/api/java

# Modified for Spring Boot + STS + AWS + Redis Project

### Java ###

# Compiled class file

*.class

# Log files

*.log

logs/

# BlueJ files

*.ctxt

# Mobile Tools for Java (J2ME)

.mtj.tmp/

# Package Files #

*.jar

*.war

*.nar

*.ear

*.zip

*.tar.gz

*.rar

# JVM crash logs

hs_err_pid*

replay_pid*

# === Eclipse / Spring Tool Suite (STS) ===

.classpath

.project

.settings/

.mvn/

# === Maven build ===

target/

# === Gradle (optional future use) ===

build/

.gradle/

# === Application configuration (민감정보) ===

src/main/resources/application.properties

.env

# === Redis (로컬 실행 시) ===

dump.rdb

# === AWS credentials (CLI 실습 시 홈 디렉토리 포함 방지) ===

.aws/

# === Editor / OS temp files ===

*.swp

*~

*.tmp

*.bak

*.old

.DS_Store

Thumbs.db

desktop.ini

# === IntelliJ IDEA (optional) ===

.idea/

*.iml

out/

# === VSCode (optional) ===

.vscode/

# === 로컬 테스트용 업로드 디렉토리 (예: 이미지 임시저장 폴더) ===

upload/


